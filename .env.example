# Copy this file to .env and fill in your values before running docker compose.
# All keys are optional except FINNHUB_API_KEY (required for news/earnings overlays).

# ── Compose toggles ───────────────────────────────────────────────────────────
# Enable the scheduled batch jobs (pipeline/alert/optimize cron). Leave unset on a dev
# box so it only runs the dashboard and doesn't duplicate cron side-effects.
# Set on the production host:
# COMPOSE_PROFILES=scheduler

# ── LLM (OpenAI-compatible: llama.cpp llama-server, Ollama /v1, vLLM, …) ───────
# Preferred: full OpenAI-style base URL including /v1.
#   llama.cpp:  http://YOUR_LLM_HOST:8089/v1
LLM_BASE_URL=http://YOUR_LLM_HOST:8089/v1
# Default model id when not chosen in the UI (llama-server --alias, or an Ollama tag).
LLM_MODEL=Qwen3-8B
# API key — local servers ignore it; any non-empty string works.
LLM_API_KEY=sk-no-key-required
#
# Back-compat: if LLM_BASE_URL is unset, the app falls back to OLLAMA_HOST + "/v1".
# OLLAMA_HOST=http://YOUR_OLLAMA_IP:11434

# ── Market data ──────────────────────────────────────────────────────────────
FINNHUB_API_KEY=

# ── Alpaca — algo trading account (paper + live) ─────────────────────────────
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true
ALPACA_LIVE_API_KEY=
ALPACA_LIVE_SECRET_KEY=

# ── SnapTrade — Schwab, Robinhood, IBKR read-only portfolio + LLM insights ───
# Partner keys from https://snaptrade.com (same across all environments).
SNAPTRADE_CLIENT_ID=
SNAPTRADE_CONSUMER_KEY=
# Per-user credentials — generated once via the Robinhood dashboard setup page.
# Add these after first registration so they travel with .env across environments.
SNAPTRADE_USER_ID=stonks-local
SNAPTRADE_USER_SECRET=

# ── Discord webhook (optional) ────────────────────────────────────────────────
# Set to post watchlist changes, pipeline results, and the nightly optimize summary
# to a Discord channel. Leave unset/commented to disable (output goes to log only).
# The standalone Discord bot is disabled (commented stonks-bot service in compose).
# STONKS_DISCORD_WEBHOOK=https://discord.com/api/webhooks/...

# ── FUTURE: Matrix alerts ─────────────────────────────────────────────────────
# MATRIX_HOMESERVER=https://matrix.example.com
# MATRIX_ROOM_ID=!yourroom:example.com
# MATRIX_ACCESS_TOKEN=
