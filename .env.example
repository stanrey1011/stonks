# Copy this file to .env and fill in your values before running docker compose.
# All keys are optional except FINNHUB_API_KEY (required for news/earnings overlays).

# ── LLM ──────────────────────────────────────────────────────────────────────
# Set to your Ollama server IP. Can also be configured in the dashboard Settings page.
OLLAMA_HOST=http://YOUR_OLLAMA_IP:11434

# ── Market data ──────────────────────────────────────────────────────────────
FINNHUB_API_KEY=

# ── Alpaca — algo trading account (paper + live) ─────────────────────────────
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true
ALPACA_LIVE_API_KEY=
ALPACA_LIVE_SECRET_KEY=

# ── SnapTrade — Schwab, Robinhood, IBKR read-only portfolio + LLM insights ───
# Register at https://snaptrade.com, then link each broker via the dashboard.
# data/snaptrade_user.json is generated at runtime (on the stonks-data volume).
SNAPTRADE_CLIENT_ID=
SNAPTRADE_CONSUMER_KEY=

# ── DISABLED: Discord ─────────────────────────────────────────────────────────
# Bot and webhook alerts removed. Matrix will replace this (see Phase B).
# STONKS_DISCORD_WEBHOOK=
# DISCORD_BOT_TOKEN=

# ── FUTURE: Matrix alerts ─────────────────────────────────────────────────────
# MATRIX_HOMESERVER=https://matrix.example.com
# MATRIX_ROOM_ID=!yourroom:example.com
# MATRIX_ACCESS_TOKEN=
